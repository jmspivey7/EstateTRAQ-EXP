# Database (PostgreSQL — Replit built-in, Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Plaid (drop in when ready - sandbox credentials)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Google Maps (for real estate module)
GOOGLE_MAPS_API_KEY=

# Market Data (optional - free tier)
FMP_API_KEY=

# AI (optional - for document categorization and asset summaries)
OPENAI_API_KEY=
