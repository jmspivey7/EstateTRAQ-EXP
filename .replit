modules = ["nodejs-20:v8-20230920-bd784b9"]

run = "npm run dev"
entrypoint = "src/app/page.tsx"

hidden = [".build", ".config"]

[nix]
channel = "stable-24_05"

[env]
NEXT_TELEMETRY_DISABLED = "1"

[deployment]
run = ["sh", "-c", "npm run build && npm run start"]

[[ports]]
localPort = 3000
externalPort = 80
